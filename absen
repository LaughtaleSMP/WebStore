<title>Absensi X6 — SMA Bina Warga 1</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --c-navy:#1a1a5e;--c-navy2:#16213e;--c-green:#155724;--c-gbg:#d4edda;--c-gborder:#b8dfc6;
  --c-yellow:#856404;--c-ybg:#fff3cd;--c-yborder:#f0d880;
  --c-blue:#004085;--c-bbg:#cce5ff;--c-bborder:#9ec8f8;
  --c-red:#721c24;--c-rbg:#f8d7da;--c-rborder:#f1a7ad;
  --c-gray:#888;--c-graybg:#e9ecef;--c-grayborder:#dde2e8;
  --bg:#f0f2f5;--card-bg:#fff;--text:#1a1a2e;--text2:#555;--border:#e0e4ef;
}
html,body{height:100%;overflow:hidden}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);display:flex;flex-direction:column}

/* HEADER */
.hdr{background:var(--c-navy);color:#fff;padding:12px 16px;flex-shrink:0}
.hdr h1{font-size:15px;font-weight:700}
.hdr p{font-size:11px;opacity:.75;margin-top:2px}

/* SEARCH */
.search-wrap{background:#fff;padding:10px 12px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;gap:8px;align-items:center}
.search-wrap input{flex:1;border:1.5px solid var(--border);border-radius:20px;padding:8px 14px;font-size:14px;outline:none;color:var(--text)}
.search-wrap input:focus{border-color:var(--c-navy)}
.search-icon{color:#888;font-size:18px}

/* TABS — horizontal scroll */
.tabs-wrap{background:#fff;border-bottom:2px solid var(--border);flex-shrink:0;overflow-x:auto;scrollbar-width:none}
.tabs-wrap::-webkit-scrollbar{display:none}
.tabs{display:flex;white-space:nowrap;padding:0 8px}
.tab-btn{padding:10px 14px;font-size:12px;font-weight:700;color:#888;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;flex-shrink:0}
.tab-btn.active{color:var(--c-navy);border-bottom-color:var(--c-navy)}

/* STAT BAR */
.stat-bar{background:#fff;padding:8px 12px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;gap:6px;overflow-x:auto;scrollbar-width:none}
.stat-bar::-webkit-scrollbar{display:none}
.stat-chip{display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:20px;font-size:12px;font-weight:700;flex-shrink:0}
.chip-h{background:var(--c-gbg);color:var(--c-green)}
.chip-t{background:var(--c-ybg);color:var(--c-yellow)}
.chip-s{background:var(--c-bbg);color:var(--c-blue)}
.chip-i{background:#e8f5e8;color:#2e7d2e}
.chip-a{background:var(--c-rbg);color:var(--c-red)}

/* MAIN SCROLL */
.main{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}

/* REKAP VIEW — card list */
.student-list{padding:10px 12px;display:flex;flex-direction:column;gap:8px}
.s-card{background:var(--card-bg);border-radius:12px;border:1px solid var(--border);overflow:hidden;cursor:pointer;transition:box-shadow .15s;active:transform:scale(0.99)}
.s-card:active{box-shadow:0 2px 12px rgba(0,0,0,0.12)}
.s-card-head{display:flex;align-items:center;padding:10px 12px;gap:10px}
.s-avatar{width:36px;height:36px;border-radius:50%;background:var(--c-navy);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0}
.s-name{font-size:14px;font-weight:700;color:var(--text);flex:1;line-height:1.3}
.s-no{font-size:11px;color:#aaa;font-weight:600}
.s-badges{display:flex;gap:4px;padding:0 12px 10px;flex-wrap:wrap}
.badge{padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700}
.badge-h{background:var(--c-gbg);color:var(--c-green)}
.badge-t{background:var(--c-ybg);color:var(--c-yellow)}
.badge-s{background:var(--c-bbg);color:var(--c-blue)}
.badge-i{background:#e8f5e8;color:#2e7d2e}
.badge-a{background:var(--c-rbg);color:var(--c-red)}
.s-detail{border-top:1px solid var(--border);padding:10px 12px;display:none}
.s-detail.open{display:block}
.month-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-bottom:8px}
.month-row{background:#f8f9ff;border-radius:8px;padding:7px 10px}
.month-lbl{font-size:10px;font-weight:700;color:#888;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
.month-stats{display:flex;gap:4px;flex-wrap:wrap}
.ms{font-size:11px;font-weight:800;padding:2px 6px;border-radius:4px}
.daily-wrap{margin-top:8px}
.daily-lbl{font-size:11px;font-weight:700;color:#888;margin-bottom:6px}
.daily-grid{display:flex;flex-wrap:wrap;gap:3px}
.dc{width:26px;height:26px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0}
.dc-H{background:var(--c-gbg);color:var(--c-green);border:1px solid var(--c-gborder)}
.dc-T{background:var(--c-ybg);color:var(--c-yellow);border:1px solid var(--c-yborder)}
.dc-S{background:var(--c-bbg);color:var(--c-blue);border:1px solid var(--c-bborder)}
.dc-I{background:#e8f5e8;color:#2e7d2e;border:1px solid #a8d5a8}
.dc-A{background:var(--c-rbg);color:var(--c-red);border:1px solid var(--c-rborder)}
.dc-L{background:var(--c-graybg);color:#bbb;border:1px solid var(--c-grayborder);font-size:8px}

/* MONTHLY TABLE VIEW */
.tbl-view{padding:10px 12px}
.tbl-outer{background:var(--card-bg);border-radius:12px;border:1px solid var(--border);overflow:hidden}
.tbl-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch}
.tbl-scroll::-webkit-scrollbar{height:4px}
.tbl-scroll::-webkit-scrollbar-track{background:#f0f2f5}
.tbl-scroll::-webkit-scrollbar-thumb{background:#bbb;border-radius:4px}
table{border-collapse:collapse;font-size:11px}
thead th{background:var(--c-navy);color:#fff;padding:8px 5px;text-align:center;white-space:nowrap;font-weight:700;font-size:10px;position:sticky;top:0;z-index:8}
thead th.sub{background:var(--c-navy2);color:#c8d0f0;font-size:10px;padding:5px 3px}
th.st-no{position:sticky;left:0;z-index:12;width:28px;min-width:28px}
th.st-nama{position:sticky;left:28px;z-index:12;width:130px;min-width:130px;text-align:left;padding-left:8px}
th.st-no.sub{position:sticky;left:0;z-index:12}
th.st-nama.sub{position:sticky;left:28px;z-index:12;text-align:left;padding-left:8px}
td.td-no{position:sticky;left:0;z-index:5;background:inherit;width:28px;font-size:11px;font-weight:700;color:#888;text-align:center;padding:2px 3px}
td.td-nama{position:sticky;left:28px;z-index:5;background:inherit;width:130px;font-size:11px;font-weight:700;white-space:nowrap;padding:0 8px;color:var(--text)}
tbody tr:nth-child(odd){background:#fcfcff}
tbody tr:nth-child(even){background:#f7f9ff}
tbody tr:active{background:#eef0ff}
.dc-td{width:22px;min-width:22px;padding:2px 1px;text-align:center}
.dc-sm{width:20px;height:24px;border-radius:4px;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:9px;font-weight:800}
.dc-sm.dc-H{background:var(--c-gbg);color:var(--c-green)}
.dc-sm.dc-T{background:var(--c-ybg);color:var(--c-yellow)}
.dc-sm.dc-S{background:var(--c-bbg);color:var(--c-blue)}
.dc-sm.dc-I{background:#e8f5e8;color:#2e7d2e}
.dc-sm.dc-A{background:var(--c-rbg);color:var(--c-red)}
.dc-sm.dc-L{background:var(--c-graybg);color:#ccc;font-size:7px}
td.rk-h{background:var(--c-gbg);color:var(--c-green);font-weight:800;text-align:center;padding:2px 5px;font-size:11px;border-left:2px solid var(--c-gborder)}
td.rk-t{background:var(--c-ybg);color:var(--c-yellow);font-weight:800;text-align:center;padding:2px 5px;font-size:11px}
td.rk-s{background:var(--c-bbg);color:var(--c-blue);font-weight:800;text-align:center;padding:2px 5px;font-size:11px}
td.rk-i{background:#e8f5e8;color:#2e7d2e;font-weight:800;text-align:center;padding:2px 5px;font-size:11px}
td.rk-a{background:var(--c-rbg);color:var(--c-red);font-weight:800;text-align:center;padding:2px 5px;font-size:11px}
th.rk-sub{background:#0d1429;color:#a0b0e0;font-size:9px;border-left:2px solid rgba(255,255,255,0.2)}

/* LEGEND */
.legend-row{display:flex;gap:8px;flex-wrap:wrap;padding:8px 12px;background:#fff;border-bottom:1px solid var(--border);flex-shrink:0}
.leg{display:flex;align-items:center;gap:4px;font-size:11px;font-weight:700}
.leg-dot{width:18px;height:18px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800}

/* HIDDEN */
.page{display:none}.page.active{display:block}
</style>
</head>
