let currentTab='rekap';
const colors={H:'#155724',T:'#856404',S:'#004085',I:'#2e7d2e',A:'#721c24'};
const bgs={H:'#d4edda',T:'#fff3cd',S:'#cce5ff',I:'#e8f5e8',A:'#f8d7da'};

function initials(n){return n.split(' ').slice(0,2).map(w=>w[0]||'').join('').toUpperCase()}

function buildRekap(){
  const el=document.getElementById('page-rekap');
  el.innerHTML=STUDENTS.map((name,i)=>{
    const totals=[0,0,0,0,0];
    MONTHS.forEach(m=>{const d=MONTHLY[m][i];d.forEach((v,j)=>totals[j]+=v)});
    const ini=initials(name);
    const pct=Math.round(totals[0]/(totals[0]+totals[1]+totals[2]+totals[3]+totals[4]||1)*100);
    const pctColor=pct>=90?'#155724':pct>=75?'#856404':'#721c24';
    const pctBg=pct>=90?'#d4edda':pct>=75?'#fff3cd':'#f8d7da';
    return `<div class="s-card" onclick="toggleCard(this,${i})" data-name="${name.toLowerCase()}">
      <div class="s-card-head">
        <div class="s-avatar">${ini}</div>
        <div style="flex:1">
          <div class="s-name">${name}</div>
          <div style="font-size:11px;color:#888;margin-top:2px">No. ${i+1}</div>
        </div>
        <div style="text-align:right">
          <div style="background:${pctBg};color:${pctColor};padding:3px 8px;border-radius:8px;font-size:12px;font-weight:800">${pct}%</div>
          <div style="font-size:10px;color:#aaa;margin-top:2px">kehadiran</div>
        </div>
      </div>
      <div class="s-badges">
        <span class="badge badge-h">H: ${totals[0]}</span>
        <span class="badge badge-t">T: ${totals[1]}</span>
        <span class="badge badge-s">S: ${totals[2]}</span>
        <span class="badge badge-i">I: ${totals[3]}</span>
        ${totals[4]>0?`<span class="badge badge-a">A: ${totals[4]}</span>`:''}
      </div>
      <div class="s-detail" id="detail-${i}"></div>
    </div>`;
  }).join('');
}

function toggleCard(card,idx){
  const det=document.getElementById('detail-'+idx);
  if(det.classList.contains('open')){det.classList.remove('open');return}
  if(!det.innerHTML){
    let html='<div class="month-grid">';
    MONTHS.forEach(m=>{
      const d=MONTHLY[m][idx];
      html+=`<div class="month-row">
        <div class="month-lbl">${MLABEL[m]}</div>
        <div class="month-stats">
          <span class="ms badge-h">H:${d[0]}</span>
          <span class="ms badge-t">T:${d[1]}</span>
          <span class="ms badge-s">S:${d[2]}</span>
          ${d[3]>0?`<span class="ms badge-i">I:${d[3]}</span>`:''}
          ${d[4]>0?`<span class="ms badge-a">A:${d[4]}</span>`:''}
        </div>
      </div>`;
    });
    html+='</div>';
    // Show daily for selected month via mini tabs inside card
    html+=`<div class="daily-wrap" id="daily-wrap-${idx}">`;
    html+=`<div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px">`;
    MONTHS.forEach((m,mi)=>{
      html+=`<div onclick="event.stopPropagation();showDaily(${idx},'${m}')" id="dtab-${idx}-${m}" style="padding:4px 9px;border-radius:12px;font-size:10px;font-weight:700;cursor:pointer;background:${mi===0?'#1a1a5e':'#e9ecef'};color:${mi===0?'#fff':'#555'}">${MLABEL[m].split(' ')[0]}</div>`;
    });
    html+='</div>';
    html+=`<div class="daily-lbl">Tanggal per hari:</div>`;
    html+=`<div class="daily-grid" id="dgrid-${idx}"></div></div>`;
    det.innerHTML=html;
    showDaily(idx,'okt');
  }
  det.classList.add('open');
}

function showDaily(idx,m){
  MONTHS.forEach(mm=>{
    const el=document.getElementById(`dtab-${idx}-${mm}`);
    if(el){el.style.background=mm===m?'#1a1a5e':'#e9ecef';el.style.color=mm===m?'#fff':'#555'}
  });
  const grid=document.getElementById(`dgrid-${idx}`);
  if(!grid)return;
  const days=MDAYS[m];
  const data=DAILY[m].data[idx];
  let html='';
  for(let d=0;d<days;d++){
    const v=data[d]||'';
    if(v==='_'||v===''){html+=`<div class="dc" style="background:#f5f5f5;border:1px dashed #ddd;color:#ddd;font-size:8px">${d+1}</div>`;continue;}
    const cls=`dc dc-${v}`;
    html+=`<div class="${cls}" title="Tgl ${d+1}: ${v}">${v}</div>`;
  }
  grid.innerHTML=html;
}

function buildMonthTable(m){
  const days=MDAYS[m];
  const el=document.getElementById('page-'+m);
  let cols='';
  for(let d=1;d<=days;d++) cols+=`<col style="width:22px;min-width:22px">`;
  let head=`<table><colgroup><col style="width:28px"><col style="width:130px">${cols}<col style="width:24px"><col style="width:24px"><col style="width:24px"><col style="width:24px"><col style="width:24px"></colgroup>`;
  head+=`<thead><tr><th class="st-no" rowspan="2">No</th><th class="st-nama" rowspan="2">${MLABEL[m]}</th>`;
  for(let d=1;d<=days;d++) head+=`<th>${d}</th>`;
  head+=`<th class="rk-sub" style="border-left:2px solid rgba(255,255,255,0.3)" colspan="5">Rekap</th></tr>`;
  head+=`<tr>`;
  for(let d=1;d<=days;d++) head+=`<th class="sub"></th>`;
  head+=`<th class="rk-sub sub">H</th><th class="rk-sub sub">T</th><th class="rk-sub sub">S</th><th class="rk-sub sub">I</th><th class="rk-sub sub">A</th></tr></thead><tbody>`;
  let body='';
  STUDENTS.forEach((name,i)=>{
    const rec=MONTHLY[m][i];
    const ddata=DAILY[m].data[i];
    body+=`<tr data-name="${name.toLowerCase()}"><td class="td-no">${i+1}</td><td class="td-nama">${name}</td>`;
    for(let d=0;d<days;d++){
      const v=ddata[d]||'';
      if(v==='_'||v===''){body+=`<td class="dc-td"></td>`;continue;}
      body+=`<td class="dc-td"><div class="dc-sm dc-${v}">${v}</div></td>`;
    }
    body+=`<td class="rk-h">${rec[0]}</td><td class="rk-t">${rec[1]}</td><td class="rk-s">${rec[2]}</td><td class="rk-i">${rec[3]}</td><td class="rk-a">${rec[4]}</td></tr>`;
  });
  body+='</tbody></table>';
  el.innerHTML=`<div class="tbl-outer"><div class="tbl-scroll">${head}${body}</div></div>`;
}

function showTab(tab,btn){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+tab).classList.add('active');
  currentTab=tab;
  filterAll();
  updateStats();
  // scroll tab into view
  btn.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
}

function filterAll(){
  const q=document.getElementById('searchBox').value.toLowerCase().trim();
  const pg=document.getElementById('page-'+currentTab);
  if(!pg)return;
  pg.querySelectorAll('[data-name]').forEach(el=>{
    const n=el.getAttribute('data-name')||'';
    el.style.display=(!q||n.includes(q))?'':'none';
  });
}

function updateStats(){
  let h=0,t=0,s=0,ii=0,a=0;
  if(currentTab==='rekap'){
    STUDENTS.forEach((_,i)=>MONTHS.forEach(m=>{const d=MONTHLY[m][i];h+=d[0];t+=d[1];s+=d[2];ii+=d[3];a+=d[4]}));
  } else if(MONTHS.includes(currentTab)){
    STUDENTS.forEach((_,i)=>{const d=MONTHLY[currentTab][i];h+=d[0];t+=d[1];s+=d[2];ii+=d[3];a+=d[4]});
  }
  document.getElementById('statBar').innerHTML=
    `<div class="stat-chip chip-h">✓ H: ${h}</div>
     <div class="stat-chip chip-t">⏰ T: ${t}</div>
     <div class="stat-chip chip-s">🏥 S: ${s}</div>
     <div class="stat-chip chip-i">📝 I: ${ii}</div>
     <div class="stat-chip chip-a">✗ A: ${a}</div>`;
}

buildRekap();
MONTHS.forEach(m=>buildMonthTable(m));
updateStats();
</script>
